# Bridge configuration for Claude Code
# Copy this file to .env and fill in your values
# Priority: CLI args > Environment vars > TOML file > Defaults

# === Server ===
# BRIDGE_PORT=4000
# BRIDGE_HOST=127.0.0.1

# === LLM ===
# OPENCODE_PORT=4096
# OPENCODE_MODEL=opencode/deepseek-v4-flash-free

# === Security ===
# BRIDGE_SHELL_POLICY=unrestricted   # disabled | allowlist | unrestricted
# BRIDGE_SHELL_ALLOWLIST=git,ls,pwd,cat,echo
# BRIDGE_AUTH_TOKEN=sk-abc,sk-xyz   # comma-separated tokens, unset = auth disabled

# === Limits ===
# BRIDGE_MAX_BODY_SIZE=1048576       # 1MB
# BRIDGE_MAX_SEARCH_LOOPS=5
# BRIDGE_RATE_LIMIT=                # max concurrent requests, unset = unlimited

# === Web Search API Keys ===
# TAVILY_API_KEY=tvly-...
# EXA_API_KEY=...
# SERPER_API_KEY=...
# SEARXNG_URL=https://searxng.example.com
# SEARXNG_API_KEY=...
